# syntax=docker/dockerfile:1.7
FROM nvidia/cuda:12.8.1-cudnn-runtime-ubuntu22.04 AS builder

ENV DEBIAN_FRONTEND=noninteractive \
    PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    UV_LINK_MODE=copy \
    PATH="/root/.local/bin:${PATH}"

WORKDIR /workspace/app/backend

RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        software-properties-common \
        curl \
        ca-certificates \
    && add-apt-repository ppa:deadsnakes/ppa \
    && apt-get update \
    && apt-get install -y --no-install-recommends \
        python3.11 \
        python3.11-venv \
        python3.11-dev \
    && rm -rf /var/lib/apt/lists/*

RUN curl -LsSf https://astral.sh/uv/install.sh | sh

COPY app/backend/pyproject.toml app/backend/uv.lock ./
RUN --mount=type=cache,target=/root/.cache/uv \
    uv sync --frozen --no-dev --no-editable --no-install-project \
    --extra kokoro --extra qwen --extra gpu --python 3.11

COPY app/backend ./
RUN --mount=type=cache,target=/root/.cache/uv \
    uv sync --frozen --no-dev --no-editable \
    --extra kokoro --extra qwen --extra gpu --python 3.11
RUN .venv/bin/python -m spacy download en_core_web_sm

FROM nvidia/cuda:12.8.1-cudnn-runtime-ubuntu22.04 AS runtime

ENV DEBIAN_FRONTEND=noninteractive \
    PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PATH="/workspace/app/backend/.venv/bin:${PATH}"

WORKDIR /workspace/app/backend

RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        software-properties-common \
        ffmpeg \
        ca-certificates \
    && add-apt-repository ppa:deadsnakes/ppa \
    && apt-get update \
    && apt-get install -y --no-install-recommends \
        python3.11 \
        python3.11-venv \
    && rm -rf /var/lib/apt/lists/*

COPY --from=builder /workspace/app/backend /workspace/app/backend

ENV MODEL_ROOT=/workspace/runtime/models \
    OUTPUT_ROOT=/workspace/runtime/output \
    JOBS_ROOT=/workspace/runtime/data/jobs \
    VOICE_SAMPLES_ROOT=/workspace/runtime/data/voices \
    LOGS_ROOT=/workspace/runtime/logs \
    OFFLINE_MODE=true \
    DEMO_MODE=false \
    ENABLE_QWEN=true \
    QWEN_ENABLED_IN_UI=true \
    NVIDIA_VISIBLE_DEVICES=all \
    NVIDIA_DRIVER_CAPABILITIES=compute,utility

EXPOSE 8000

CMD ["python", "-m", "uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "8000"]
